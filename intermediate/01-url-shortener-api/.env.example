# Copy to .env and adjust as needed. All values have safe local defaults, so the
# app runs without any secret. Every variable is prefixed URLSHORTENER_.

# SQLAlchemy database URL. SQLite by default for a zero-setup local experience.
URLSHORTENER_DATABASE_URL=sqlite:///./url_shortener.db

# Public base URL used to build short links in API responses.
URLSHORTENER_BASE_URL=http://localhost:8000

# Logging level (DEBUG, INFO, WARNING, ERROR).
URLSHORTENER_LOG_LEVEL=INFO

# Length of generated short codes (4-32).
URLSHORTENER_CODE_LENGTH=7
